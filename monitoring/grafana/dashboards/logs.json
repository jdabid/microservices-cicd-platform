        "options": [],
        "query": "loki",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "loki", "uid": "${datasource}" },
        "definition": "label_values(service)",
        "hide": 0,
        "includeAll": true,
        "label": "Service",
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(service)",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "hide": 0,
        "includeAll": true,
        "label": "Level",
        "multi": true,
        "name": "level",
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "DEBUG", "value": "DEBUG" },
          { "selected": false, "text": "INFO", "value": "INFO" },
          { "selected": false, "text": "WARNING", "value": "WARNING" },
          { "selected": false, "text": "ERROR", "value": "ERROR" },
          { "selected": false, "text": "CRITICAL", "value": "CRITICAL" }
        ],
        "query": "DEBUG,INFO,WARNING,ERROR,CRITICAL",
        "skipUrlSync": false,
        "type": "custom"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Search",
        "name": "search",
        "options": [
          { "selected": true, "text": "", "value": "" }
        ],
        "query": "",
