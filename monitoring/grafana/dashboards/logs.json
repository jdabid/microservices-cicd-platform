{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "Logs/s",
            "drawStyle": "bars",
            "fillOpacity": 50,
            "gradientMode": "none",
            "lineWidth": 1,
            "pointSize": 5,
            "stacking": { "group": "A", "mode": "normal" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "error" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "warning" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "info" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "debug" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (level) (count_over_time({service=~\"$service\"} | json | level=~\"$level\" [$__auto]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "title": "Log Volume Over Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 6 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=~\"$service\"} [$__range]))",
          "refId": "A"
        }
      ],
      "title": "Total Logs",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 6 },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=~\"$service\"} | json | level=\"ERROR\" [$__range]))",
          "refId": "A"
        }
      ],
      "title": "Error Count",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 6 },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=~\"$service\"} | json | level=\"WARNING\" [$__range]))",
          "refId": "A"
        }
      ],
      "title": "Warning Count",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 6 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum(count_over_time({service=~\"$service\"} | json | level=\"INFO\" [$__range]))",
          "refId": "A"
        }
      ],
      "title": "Info Count",
      "type": "stat"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 10 },
      "id": 6,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=~\"$service\"} | json | level=~\"$level\" |= \"$search\"",
          "refId": "A"
        }
      ],
      "title": "Application Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 30,
            "lineWidth": 1,
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 24 },
      "id": 7,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "sum by (service) (count_over_time({service=~\"$service\"} | json | level=\"ERROR\" [$__auto]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "title": "Error Logs by Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 30 },
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${datasource}" },
          "expr": "{service=~\"$service\"} | json | level=\"ERROR\"",
          "refId": "A"
        }
      ],
      "title": "Error Logs Detail",
      "type": "logs"
    }
  ],
  "schemaVersion": 39,
  "tags": ["loki", "logs", "monitoring"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Loki", "value": "Loki" },
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
